# EchoMind 本地开发环境变量
# 使用方式（二选一）：
#   1. 复制到 .env：  cp .env.dev .env
#   2. 在 IDEA 运行配置的环境变量中逐项添加
#
# 与 .env 的主要区别：
#   - APP_ENV=development → uvicorn 自动开启 --reload
#   - REDIS_URL 改为 localhost（连接宿主机上 docker 映射的端口）
#   - CHROMA_HOST/PORT 改为 localhost（连接宿主机上 docker 映射的端口）
#   - LOG_LEVEL=DEBUG → 打出更详细的日志

# ── Anthropic / DeepSeek ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-92f09f3ada494ecd8390763ff293906b
ANTHROPIC_MODEL=deepseek-chat
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# ── 应用（开发模式）───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=DEBUG
API_HOST=0.0.0.0
API_PORT=8000

# ── Redis（通过 Docker 映射端口连接）─────────────────────────────────────────────
REDIS_PASSWORD=echomind123
REDIS_URL=redis://:echomind123@localhost:6379/0

# ── ChromaDB（通过 Docker 映射端口连接）─────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIRECTORY=/app/data/chroma

# ── RabbitMQ（体验券超时检测）───────────────────────────────────────────────────
RABBITMQ_USER=echomind
RABBITMQ_PASS=echomind123
RABBITMQ_URL=amqp://echomind:echomind123@localhost:5672/

# ── 监控 ──────────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9091
MONITOR_INTERVAL=10
ALERT_WEBHOOK_URL=
