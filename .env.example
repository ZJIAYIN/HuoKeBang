# EchoMind 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ── 应用 ──────────────────────────────────────────────────────────────────────
APP_NAME=EchoMind
APP_ENV=production
LOG_LEVEL=INFO

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Anthropic Claude ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-92f09f3ada494ecd8390763ff293906b

# 可选：覆盖为兼容 Anthropic 协议的第三方 API（如 DeepSeek）
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# 可选：覆盖模型名称（默认 claude-3-5-sonnet-20241022）
# 使用 DeepSeek 时设为 deepseek-chat
# ANTHROPIC_MODEL=deepseek-chat

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=echomind123

# ── RabbitMQ（体验券超时检测）───────────────────────────────────────────────────
RABBITMQ_USER=echomind
RABBITMQ_PASS=echomind123
RABBITMQ_URL=amqp://echomind:echomind123@localhost:5672/

# ── MySQL（体验券持久化）─────────────────────────────────────────────────────────
MYSQL_URL=mysql://echomind:echomind123@localhost:3307/echomind

# ── 向量嵌入模型 ────────────────────────────────────────────────────────────────
# 使用 BGE 中文系列（ONNX 轻量版，通过 fastembed 加载，无需 PyTorch）
# 可选: BAAI/bge-small-zh-v1.5 (384维) / BAAI/bge-base-zh-v1.5 (768维) / BAAI/bge-large-zh-v1.5 (1024维)
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ── Milvus 向量数据库 ──────────────────────────────────────────────────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530

# RAG 置信度闸门：检索结果 LLM 评判分数低于此值时拒绝注入知识库上下文
RAG_CONFIDENCE_THRESHOLD=0.5

# ── 监控 ──────────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9091
ANOMALY_DETECTION_THRESHOLD=2.0

# ── 评测 ──────────────────────────────────────────────────────────────────────
EVAL_BASELINE_PATH=./data/eval/baseline.json

# ── 安全 ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_in_production
JWT_SECRET_KEY=change_this_in_production

# ── Langfuse 可观测性（可选，不配置则跳过）───────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── 功能开关 ──────────────────────────────────────────────────────────────────
ENABLE_SWAGGER_UI=true
ENABLE_MONITORING=true
ENABLE_EVALUATION=true
